<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <% page_title = current_page.data.title || "tklon.com" %>
    <% description = current_page.data.description || "tklon.com — a personal blog." %>
    <% canonical = "https://tklon.com#{current_page.url}" %>

    <title><%= h(page_title) %></title>
    <meta name="description" content="<%= h(description) %>">
    <link rel="canonical" href="<%= h(canonical) %>">

    <meta property="og:title" content="<%= h(page_title) %>">
    <meta property="og:description" content="<%= h(description) %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= h(canonical) %>">
    <meta property="og:site_name" content="tklon.com">
    <meta name="twitter:card" content="summary">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700&display=swap">

    <%= stylesheet_link_tag :all %>
  </head>

  <body class="<%= page_classes %>">
    <%= yield %>
  </body>
</html>
