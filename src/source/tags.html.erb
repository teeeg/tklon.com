---
title: posts
layout: layouts/default
---
<h1 class="visually-hidden">All posts</h1>
<p>
  Filter by tag:
  <% blog.tags.each_key do |tag| %>
    <%= partial('partials/tag', :locals => { :tag => tag })%>
  <% end %>
</p>

<ul class="Articles">
<% page_articles.each do |article| %>
  <li class="Article <%= article.tags.join(' ') %>">
    <%= link_to article.title, article %>
    <time class="date" datetime="<%= article.date.strftime("%F") %>"><%= article.date.strftime("%b %Y") %></time>
  </li>
<% end %>
</ul>

<%= partial "partials/banner" %>
<%= javascript_include_tag  :tags %>
