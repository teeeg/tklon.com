<%#
  Responsive image partial. Pass :name (the original's basename in src/images/,
  without extension), :alt_text, and an optional :caption. Variants and
  dimensions come from data/images.json, generated by scripts/build-images.mjs.
  Prefer the responsive_image helper, e.g. in a post:
    responsive_image "speedbox-motor-exposed", alt: "Exposed Bosch e-bike motor"
    responsive_image "yogurt-setup", caption: "My fermentation rig"
    responsive_image "diagram", alt: "Schematic of the rig", caption: "Fig 1."
%>
<%
  images = data.respond_to?(:images) ? data.images : nil
  meta = images && images[name]
  raise "Unknown image '#{name}' — run `make build` (scripts/build-images.mjs)" unless meta
  widths = meta["widths"]
  fallback_width = widths.include?(750) ? 750 : widths.max
  srcset = ->(ext) { widths.map { |w| "/images/#{name}-#{w}.#{ext} #{w}w" }.join(", ") }
  sizes = "(min-width: 750px) 750px, 100vw"
%>
<figure>
    <picture>
        <source type="image/avif" sizes="<%= sizes %>" srcset="<%= srcset.("avif") %>" />
        <source type="image/webp" sizes="<%= sizes %>" srcset="<%= srcset.("webp") %>" />
        <img src="/images/<%= name %>-<%= fallback_width %>.webp"
             width="<%= meta["width"] %>" height="<%= meta["height"] %>"
             loading="lazy" decoding="async" alt="<%= h(alt_text) %>" />
    </picture>
    <% if defined?(caption) && caption %><figcaption><%= h(caption) %></figcaption><% end %>
</figure>
