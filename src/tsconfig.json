  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "removeComments": true,
    "moduleResolution": "bundler"
  },
  "include": ["source/typescripts/**/*.ts"]
}
