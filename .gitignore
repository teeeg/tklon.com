# manifests, so it never bloats with large binaries.
site/images/
site/videos/

# `cloudformation package` output (regenerated by `make infra`)
deploy/template.packaged.yml

# python bytecode + lint cache (deploy/lambda tooling)
__pycache__/
.ruff_cache/
